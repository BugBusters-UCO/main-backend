# Runtime
NODE_ENV=production
PORT=5000
JWT_SECRET=replace-with-a-secret-from-the-bank-secret-store
AGENT_SHARED_TOKEN=replace-with-a-secret-from-the-bank-secret-store

# Database
DB_ENABLED=true
DATABASE_URL=postgres://scanner_user:password@postgres.internal:5432/bugbusters
DB_SSL=true

# Redis Streams queue. Keep credentials out of source control.
REDIS_ENABLED=true

# Upstash REST option. If both values are present, the queue automatically uses Upstash.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-secret-manager-value
REDIS_PROVIDER=upstash-rest

REDIS_URL=rediss://:password@redis.internal:6380/0
# Alternatively use REDIS_HOST/PORT/USERNAME/PASSWORD/DB/TLS.
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=replace-with-secret-store-value
REDIS_DB=0
REDIS_TLS=true
REDIS_SCAN_STREAM=bugbusters:scan-jobs
REDIS_SCAN_DLQ_STREAM=bugbusters:scan-jobs:dead-letter
REDIS_SCAN_GROUP=bugbusters:scan-workers
REDIS_SCAN_CONSUMER=backend-worker-1
SCAN_WORKER_CONCURRENCY=4
REDIS_SCAN_POLL_MS=2000
REDIS_SCAN_CLAIM_IDLE_MS=60000
REDIS_SCAN_MAX_ATTEMPTS=3
REDIS_SCHEDULE_STREAM=bugbusters:scheduled-scans
REDIS_SCHEDULE_DLQ_STREAM=bugbusters:scheduled-scans:dead-letter
REDIS_SCHEDULE_GROUP=bugbusters-scheduled-workers
REDIS_SCHEDULE_MAX_ATTEMPTS=3

# Internal scanner service authentication
SCANNER_API_TOKEN=replace-with-secret-store-value
DEPENDENCY_SCANNER_URL=http://dependency-scanner.internal:8001

# Signed provider webhooks and private clone credentials.
GITHUB_WEBHOOK_SECRET=replace-with-secret-manager-value
GITLAB_WEBHOOK_SECRET=replace-with-secret-manager-value
BITBUCKET_WEBHOOK_SECRET=replace-with-secret-manager-value
AZURE_DEVOPS_WEBHOOK_SECRET=replace-with-secret-manager-value
GITHUB_ENTERPRISE_HOSTS=github.example.bank
GITLAB_ENTERPRISE_HOSTS=gitlab.example.bank
BITBUCKET_ENTERPRISE_HOSTS=bitbucket.example.bank
AZURE_DEVOPS_HOSTS=dev.azure.com
GITHUB_ENTERPRISE_TOKEN=replace-with-secret-manager-value
GITLAB_TOKEN=replace-with-secret-manager-value
BITBUCKET_TOKEN=replace-with-secret-manager-value
AZURE_DEVOPS_TOKEN=replace-with-secret-manager-value

# Internal advisory ingestion. Configure NVD to an approved feed or mirror.
OSV_ADVISORY_URL=https://api.osv.dev/v1/vulns
NVD_FEED_URL=
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
ADVISORY_ALLOW_CUSTOM_FEEDS=false
ADVISORY_OFFLINE_MODE=true
ADVISORY_SOURCE_MODE=manual
ADVISORY_ALLOW_EXTERNAL_FEEDS=false
INTERNAL_ADVISORY_HOSTS=advisory-mirror.internal.bank
BANK_INTERNAL_ONLY=true
BANKING_STRICT_OFFLINE=true

# Enterprise identity controls. Connect these to the bank IdP/secret manager.
SSO_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
MFA_REQUIRED=false
MFA_ENCRYPTION_KEY=replace-with-secret-manager-value

# Container/SBOM scanning workers.
TRIVY_PATH=trivy
TRIVY_OFFLINE_SCAN=true
SYFT_PATH=syft
CONTAINER_SCAN_TIMEOUT_SECONDS=120
CONTAINER_SCAN_ROOTS=

# Infrastructure-as-Code scanning workers.
CHECKOV_PATH=checkov
IAC_SCAN_ROOTS=
IAC_SCAN_TIMEOUT_SECONDS=120
